{% extends 'base.html.twig' %}

{% block title %}Inscription - SimpleBudget{% endblock %}

{% block body %}
    <div class="flex items-center justify-center min-h-screen">
        <div class="m-4 md:m-auto p-4 md:p-8 lg:p-12 rounded shadow-md w-full md:w-96 lg:w-96">
            <h1 class="text-2xl font-semibold mb-4 text-center">Inscription</h1>
            {% for flash_error in app.flashes('verify_email_error') %}
                <div class="alert alert-danger" role="alert">{{ flash_error }}</div>
            {% endfor %}

            {{ form_start(registrationForm) }}
            {{ form_errors(registrationForm) }}
            <div class="mb-4">
                {{ form_label(registrationForm.email) }}
                {% if form_errors(registrationForm.email) is not empty %}
                    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-2" role="alert">
                        {{ form_errors(registrationForm.email) }}
                    </div>
                {% endif %}
                {{ form_widget(registrationForm.email) }}
            </div>

            <div class="mb-4">
                {{ form_label(registrationForm.plainPassword) }}
                {% if form_errors(registrationForm.plainPassword) is not empty %}
                    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-2" role="alert">
                        {{ form_errors(registrationForm.plainPassword) }}
                    </div>
                {% endif %}
                {{ form_widget(registrationForm.plainPassword) }}
            </div>

            <div class="mb-4">
                {% if form_errors(registrationForm.agreeTerms) is not empty %}
                    <div class="bg-red-100 border border-red-400 text-red-700 px-4 py-3 rounded relative mb-2" role="alert">
                        Vous devez accepter les conditions d'utilisation.
                    </div>
                {% endif %}
                {{ form_widget(registrationForm.agreeTerms) }}
                {{ form_label(registrationForm.agreeTerms) }}
            </div>

            <button type="submit"
                    class="w-full bg-blue-500 text-white py-2 px-4 rounded hover:bg-blue-600 focus:outline-none focus:ring focus:border-blue-300">
                S'inscrire
            </button>
            {{ form_end(registrationForm) }}
            <div class="mt-4 text-center">
            <a href="{{ path('app_login') }}" class="text-blue-500 hover:underline">Se connecter</a>
            </div>
        </div>

    </div>
{% endblock %}
