{% extends 'base.html.twig' %}
{% form_theme budgetForm 'bootstrap_5_layout.html.twig' %}

{% block title %}Ajouter un budget - SimpleBudget{% endblock %}

{% block body %}
    <div class="container mx-auto px-4">
        <div class="mb-4">
            <a href="{{ path('app_budget') }}" class="btn btn-outline-primary mt-4">Retour à la liste des budgets</a>
        </div>

        <p>Bienvenue dans l'outil de création de budget. Commencez par donner un nom à votre budget, puis saisissez les
            différentes entrées (dépenses) avant d'enregistrer votre budget !</p>
        <hr>

        {{ form_start(budgetForm) }}

        {{ form_row(budgetForm.name) }}

        <div class="mt-4 mb-4">
            {{ form_label(budgetForm.budgetEntries) }}
            {{ form_errors(budgetForm.budgetEntries) }}
            {{ form_widget(budgetForm.budgetEntries) }}
        </div>

        <div class="mb-4">
            <button type="submit" class="btn btn-success mt-4">Créer mon budget</button>
        </div>

        {{ form_end(budgetForm) }}
    </div>
{% endblock %}

